# Environment variables for Qui Est-Ce ?
#
# Copy this file to .env and adjust values for your deployment.
# On AlwaysData, set these as environment variables in the hosting panel.

# PostgreSQL connection
DB_HOST=postgresql-yourusername.alwaysdata.net
DB_PORT=5432
DB_NAME=yourusername_qui_est_ce
DB_USER=yourusername_user
DB_PASS=your_password_here

# Base URL of the application (no trailing slash)
BASE_URL=https://yourusername.alwaysdata.net

# Email sender address
MAIL_FROM=noreply@yourdomain.fr
